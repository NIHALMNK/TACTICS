<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>E-commerce Navigation</title>
  <link rel="icon" type="image/x-icon" href="/images/logos/logo-phy.png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/user/dashboard.css">
</head>

<body>
 <!-------------------------------------------------------------------------------------------------------------------------------------------------------------------------->
 <%- include('./layout/NAV.ejs') %>
 <!----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------->
 
  <!-- Profile Session Container -->
   <section>
  <div class="profile-session-container">
    <div class="container">
      <div class="dashboard">
        <!-- Sidebar -->
        <div class="sidebar">
          <button class="nav-button active" data-section="dashboard">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Dashboard
          </button>
          <button class="nav-button" data-section="orders">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            Orders
          </button>
          <button class="nav-button" data-section="profile">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Update Profile
          </button>
          <button class="nav-button" data-section="address">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            My Address
          </button>
          <button class="nav-button" data-section="wallet">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            Wallet
          </button>
          <a href="/logout"><button class="nav-button" data-section="logout">
            logout
          </button></a>
        </div>

        <!-- Main Content -->
        <div class="main-content">
          <!-- Dashboard Section -->
          <div class="section active" id="dashboard">
            <h2 class="section-title">Dashboard</h2>
            <p>
              Welcome to your dashboard! Here you can manage your orders,
              profile, and more.
            </p>
          </div>

          <!-- Orders Section -->
          <div class="section" id="orders">
            <h2 class="section-title">Your Orders</h2>
            <div class="order-card">
              <img src="/images/120x120-dress/1.png" alt="Product" class="order-image" />
              <div class="order-details">
                <div class="order-status">Arriving Monday</div>
                <div class="order-meta">Order #12345</div>
              </div>
              <div class="button-group">
                <button class="btn btn-primary">Track Order</button>
                <button class="btn btn-secondary">Cancel Order</button>
              </div>
            </div>
            <div class="order-card">
              <img src="/images/120x120-dress/2.png" alt="Product" class="order-image" />
              <div class="order-details">
                <div class="order-status cancelled">Cancelled on Oct 05</div>
                <div class="order-meta">Order #12344</div>
              </div>
              <div class="button-group">
                <button class="btn btn-primary">View Details</button>
              </div>
            </div>
          </div>

          <!-- Profile Section -->
          <div class="section" id="profile">
            <h2 class="section-title">Update Profile</h2>
            <form class="profile-form">
              <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" class="form-control" placeholder="Enter username" />
              </div>
              <button type="submit" class="btn btn-primary">
                Save Changes
              </button>
            </form>
          </div>

          <!-- Address Section -->
          <div class="section" id="address">
            <h2 class="section-title">My Address</h2>
            <div class="address-card">
              <div class="address-details">
                3522 Interstate<br />
                75 Business Spur,<br />
                Sault Ste.<br />
                Marie, MI 49783
                <div class="location">New York</div>
              </div>
              <div class="address-actions">
                <a href="#" class="address-link">Edit</a>
                <a href="#" class="address-link">Remove</a>
              </div>
            </div>
            <button class="btn btn-primary">Add New Address</button>
          </div>

          <!-- Wallet Section -->
          <div class="section" id="wallet">
            <h2 class="section-title">Wallet</h2>
            <div class="wallet-card">
              <div class="wallet-holder">Nihal</div>
              <div class="wallet-number">**** **** **** 9667</div>
              <div class="wallet-balance">Rs. 4,322.89</div>
            </div>
            <div style="margin-bottom: 1.5rem">
              <input type="text" class="form-control" placeholder="Enter amount" style="margin-bottom: 1rem" />
              <button class="btn btn-primary">Add Amount</button>
            </div>
            <table class="transactions-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Amount</th>
                  <th>Type</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>1</td>
                  <td>Rs. 499.90</td>
                  <td>Debit</td>
                  <td>12/05/2024</td>
                </tr>
                <tr>
                  <td>2</td>
                  <td>Rs. 549.90</td>
                  <td>EMI</td>
                  <td>06/05/2024</td>
                </tr>
                <tr>
                  <td>3</td>
                  <td>Rs. 200.00</td>
                  <td>EMI</td>
                  <td>05/02/2024</td>
                </tr>
                <tr>
                  <td>4</td>
                  <td>Rs. 149.90</td>
                  <td>Debit</td>
                  <td>20/12/2023</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
  <!----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------->
  <%- include('./layout/FOOTER.ejs') %>
  
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
  <script>
    // Navigation handling
    const navButtons = document.querySelectorAll(".nav-button");
    const sections = document.querySelectorAll(".section");

    navButtons.forEach((button) => {
      button.addEventListener("click", () => {
        // Remove active class from all buttons and sections
        navButtons.forEach((btn) => {
          btn.classList.remove("active");
        });
        sections.forEach((section) => {
          section.classList.remove("active");
        });

        // Add active class to clicked button
        button.classList.add("active");

        // Show corresponding section
        const sectionId = button.getAttribute("data-section");
        const targetSection = document.getElementById(sectionId);
        if (targetSection) {
          targetSection.classList.add("active");
        }
      });
    });

    // Optional: Add smooth transitions for section changes
    sections.forEach((section) => {
      section.style.transition = "opacity 0.3s ease-in-out";
    });

    // Optional: Initialize the dashboard view (ensure first section is visible)
    window.addEventListener("DOMContentLoaded", () => {
      const defaultSection = document.getElementById("dashboard");
      const defaultButton = document.querySelector(
        '[data-section="dashboard"]'
      );

      if (defaultSection && defaultButton) {
        sections.forEach((section) => section.classList.remove("active"));
        navButtons.forEach((btn) => btn.classList.remove("active"));

        defaultSection.classList.add("active");
        defaultButton.classList.add("active");
      }
    });
  </script>
</body>

</html>